{"screenId":"281694b38ff04a56bcba28d761ee76af","projectId":"7164373073288149890","htmlContent":"<!DOCTYPE html>\n\n<html class=\"dark\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>NEON LUMINARY - Title Screen</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Manrope:wght@300;400;500;600;700;800&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"error\": \"#ffb4ab\",\n              \"on-surface-variant\": \"#bac9cc\",\n              \"on-error\": \"#690005\",\n              \"on-surface\": \"#e4e1e9\",\n              \"on-tertiary-fixed\": \"#23005b\",\n              \"surface-container\": \"#1f1f25\",\n              \"surface-container-highest\": \"#35343a\",\n              \"inverse-on-surface\": \"#303036\",\n              \"on-primary-fixed-variant\": \"#004f58\",\n              \"on-secondary-container\": \"#590028\",\n              \"outline-variant\": \"#3b494c\",\n              \"on-tertiary-container\": \"#6c00f7\",\n              \"on-primary-fixed\": \"#001f24\",\n              \"tertiary-fixed-dim\": \"#d1bcff\",\n              \"surface\": \"#131318\",\n              \"primary\": \"#c3f5ff\",\n              \"secondary-fixed\": \"#ffd9e1\",\n              \"surface-container-lowest\": \"#0e0e13\",\n              \"on-error-container\": \"#ffdad6\",\n              \"error-container\": \"#93000a\",\n              \"on-secondary-fixed\": \"#3f001a\",\n              \"inverse-primary\": \"#006875\",\n              \"surface-variant\": \"#35343a\",\n              \"surface-tint\": \"#00daf3\",\n              \"surface-container-low\": \"#1b1b20\",\n              \"outline\": \"#849396\",\n              \"inverse-surface\": \"#e4e1e9\",\n              \"on-tertiary\": \"#3c0090\",\n              \"background\": \"#131318\",\n              \"tertiary-container\": \"#d9c8ff\",\n              \"secondary-container\": \"#ff4a8d\",\n              \"primary-fixed\": \"#9cf0ff\",\n              \"primary-fixed-dim\": \"#00daf3\",\n              \"on-primary-container\": \"#00626e\",\n              \"on-tertiary-fixed-variant\": \"#5700c9\",\n              \"tertiary\": \"#f2e9ff\",\n              \"secondary\": \"#ffb1c4\",\n              \"surface-dim\": \"#131318\",\n              \"surface-container-high\": \"#2a292f\",\n              \"on-secondary\": \"#65002e\",\n              \"on-secondary-fixed-variant\": \"#8f0044\",\n              \"on-primary\": \"#00363d\",\n              \"tertiary-fixed\": \"#e9ddff\",\n              \"secondary-fixed-dim\": \"#ffb1c4\",\n              \"on-background\": \"#e4e1e9\",\n              \"primary-container\": \"#00e5ff\",\n              \"surface-bright\": \"#39383e\"\n            },\n            fontFamily: {\n              \"headline\": [\"Space Grotesk\"],\n              \"body\": [\"Manrope\"],\n              \"label\": [\"Space Grotesk\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0.125rem\", \"lg\": \"0.25rem\", \"xl\": \"0.5rem\", \"full\": \"0.75rem\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .neon-glow-primary {\n            text-shadow: 0 0 10px rgba(0, 229, 255, 0.8), 0 0 20px rgba(0, 229, 255, 0.4);\n        }\n        .neon-glow-secondary {\n            text-shadow: 0 0 10px rgba(255, 177, 196, 0.8), 0 0 20px rgba(255, 177, 196, 0.4);\n        }\n        .pulse-primary {\n            box-shadow: 0 0 0 0 rgba(0, 229, 255, 0.7);\n            animation: pulse 2s infinite;\n        }\n        @keyframes pulse {\n            0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(0, 229, 255, 0.7); }\n            70% { transform: scale(1.05); box-shadow: 0 0 0 20px rgba(0, 229, 255, 0); }\n            100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(0, 229, 255, 0); }\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-background text-on-surface font-body overflow-hidden selection:bg-primary-container selection:text-on-primary-container\">\n<!-- Ambient Background Light Leaks -->\n<div class=\"fixed inset-0 pointer-events-none overflow-hidden\">\n<div class=\"absolute -top-24 -left-24 w-96 h-96 bg-primary/10 blur-[120px] rounded-full\"></div>\n<div class=\"absolute top-1/2 -right-24 w-80 h-80 bg-secondary/10 blur-[100px] rounded-full\"></div>\n<div class=\"absolute -bottom-24 left-1/4 w-72 h-72 bg-primary-container/5 blur-[80px] rounded-full\"></div>\n</div>\n<!-- Top Navigation & High Score Shell -->\n<header class=\"fixed top-0 w-full z-50 flex justify-between items-center px-6 py-6 h-20\">\n<div class=\"flex items-center gap-3\">\n<div class=\"bg-surface-container-high p-2 rounded-lg flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-primary text-xl\" data-icon=\"leaderboard\">leaderboard</span>\n</div>\n<div class=\"flex flex-col\">\n<span class=\"text-[10px] font-headline font-bold tracking-[0.2em] text-secondary uppercase leading-none mb-1\">HIGH SCORE</span>\n<span class=\"text-xl font-headline font-bold tracking-tight text-on-surface neon-glow-primary\">12,345</span>\n</div>\n</div>\n<div class=\"flex items-center gap-4\">\n<button class=\"bg-surface-container-low/40 backdrop-blur-md p-3 rounded-full hover:bg-surface-container transition-all duration-300 active:scale-95 group\">\n<span class=\"material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors\" data-icon=\"settings\">settings</span>\n</button>\n</div>\n</header>\n<!-- Main Title Content Canvas -->\n<main class=\"relative z-10 w-full h-screen flex flex-col items-center justify-center px-6\">\n<!-- Game Branding -->\n<div class=\"mb-16 text-center\">\n<h1 class=\"font-headline font-extrabold text-5xl md:text-7xl tracking-tighter text-cyan-400 drop-shadow-[0_0_15px_rgba(0,229,255,0.6)] uppercase mb-2\">\n                NEON<br/>LUMINARY\n            </h1>\n<div class=\"h-1 w-24 bg-gradient-to-r from-transparent via-secondary to-transparent mx-auto rounded-full opacity-60\"></div>\n</div>\n<!-- Central Action Hero -->\n<div class=\"relative group\">\n<!-- Pulsing outer ring -->\n<div class=\"absolute -inset-1 bg-gradient-to-r from-primary to-primary-container rounded-full blur opacity-40 group-hover:opacity-75 transition duration-1000 group-hover:duration-200 pulse-primary\"></div>\n<button class=\"relative flex flex-col items-center justify-center w-48 h-48 md:w-56 md:h-56 bg-surface-container-lowest rounded-full border border-primary/20 shadow-2xl transition-transform duration-300 active:scale-90 group\">\n<span class=\"text-xs font-headline font-black tracking-[0.3em] text-primary/60 mb-2 uppercase\">ENTER VOID</span>\n<span class=\"text-5xl font-headline font-extrabold text-on-primary-fixed-variant tracking-tighter neon-glow-primary italic\">PLAY</span>\n<!-- Inner Decorative Accents -->\n<div class=\"absolute bottom-10 flex gap-1\">\n<div class=\"w-1.5 h-1.5 rounded-full bg-secondary\"></div>\n<div class=\"w-1.5 h-1.5 rounded-full bg-primary/40\"></div>\n<div class=\"w-1.5 h-1.5 rounded-full bg-primary/40\"></div>\n</div>\n</button>\n</div>\n<!-- Asymmetric Detail / World Info -->\n<div class=\"absolute bottom-32 left-8 md:left-24 max-w-[200px] hidden md:block\">\n<div class=\"space-y-4\">\n<div class=\"h-[1px] w-12 bg-primary/40\"></div>\n<p class=\"text-[10px] font-body font-medium text-on-surface-variant leading-relaxed tracking-wider uppercase\">\n                    Current Season: <span class=\"text-primary font-bold\">Midnight Overdrive</span>\n</p>\n<div class=\"flex items-center gap-3\">\n<span class=\"w-2 h-2 rounded-full bg-secondary animate-pulse shadow-[0_0_8px_#ffb1c4]\"></span>\n<span class=\"text-[10px] font-headline font-bold text-secondary tracking-widest uppercase\">Live Event Active</span>\n</div>\n</div>\n</div>\n</main>\n<!-- Bottom Navigation Shell -->\n<nav class=\"fixed bottom-10 left-0 right-0 z-50 flex justify-center items-center px-4\">\n<div class=\"flex justify-around items-center w-[280px] md:w-[320px] bg-surface-container-low/40 backdrop-blur-xl rounded-full border border-white/10 px-4 py-2 shadow-2xl\">\n<!-- Home (Active) -->\n<button class=\"flex items-center justify-center bg-cyan-400/20 text-cyan-300 rounded-full p-3 shadow-[0_0_15px_rgba(0,229,255,0.4)] transition-all duration-150 active:scale-90\">\n<span class=\"material-symbols-outlined\" data-icon=\"home\" style=\"font-variation-settings: 'FILL' 1;\">home</span>\n</button>\n<!-- Events -->\n<button class=\"flex items-center justify-center text-slate-500 p-3 hover:text-cyan-200 transition-colors duration-150 active:scale-90\">\n<span class=\"material-symbols-outlined\" data-icon=\"emoji_events\">emoji_events</span>\n</button>\n<!-- Profile -->\n<button class=\"flex items-center justify-center text-slate-500 p-3 hover:text-cyan-200 transition-colors duration-150 active:scale-90\">\n<span class=\"material-symbols-outlined\" data-icon=\"account_circle\">account_circle</span>\n</button>\n</div>\n</nav>\n<!-- Visual Embellishment Footer -->\n<div class=\"fixed bottom-0 w-full px-8 py-4 flex justify-between items-end opacity-40\">\n<div class=\"flex flex-col gap-1\">\n<div class=\"flex gap-1\">\n<div class=\"w-4 h-1 bg-primary/40\"></div>\n<div class=\"w-1 h-1 bg-primary/20\"></div>\n</div>\n<span class=\"text-[8px] font-headline tracking-[0.4em] text-on-surface-variant uppercase\">Build 4.0.2 // STABLE</span>\n</div>\n<div class=\"text-right\">\n<span class=\"text-[8px] font-headline tracking-[0.2em] text-on-surface-variant uppercase\">© 2024 NEON LUMINARY LABS</span>\n</div>\n</div>\n</body></html>"}
